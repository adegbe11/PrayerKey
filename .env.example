# ══════════════════════════════════════════════════════════════
#  PrayerKey — Environment Variables
#  Copy this file to .env.local and fill in all values.
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/prayerkey"

# For Docker Compose — individual parts (optional if using DATABASE_URL above)
POSTGRES_USER=prayerkey
POSTGRES_PASSWORD=prayerkey_secret
POSTGRES_DB=prayerkey

# ── NextAuth ──────────────────────────────────────────────────
# The public URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-here"

# ── Google OAuth (optional) ───────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Groq (required for Prayer AI + Verse Detection) ──────────
# Free tier at: https://console.groq.com/
GROQ_API_KEY="gsk_..."

# ── Deepgram (required for Live Sermon STT) ───────────────────
# Get at: https://console.deepgram.com/
DEEPGRAM_API_KEY="..."

# ── Pinecone (required for Bible verse embeddings) ────────────
# Get at: https://app.pinecone.io/
PINECONE_API_KEY="..."
PINECONE_INDEX="prayerkey-bible"

# ── Public runtime vars (exposed to browser) ──────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# ── Mobile app ────────────────────────────────────────────────
# Set in mobile/.env.local (Expo reads EXPO_PUBLIC_* prefix)
# EXPO_PUBLIC_API_URL="https://your-production-domain.com"
# EXPO_PUBLIC_SOCKET_URL="https://your-production-domain.com"
